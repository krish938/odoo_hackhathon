# Server port
PORT=3002

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/pos

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_64_char_hex_from_openssl_rand_hex_32

# JWT token expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Bcrypt hashing rounds (12 recommended for production)
BCRYPT_ROUNDS=12

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173
